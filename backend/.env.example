# ============================================================
# WEAVIATE CONFIGURATION
# ============================================================

# Weaviate Cloud (WCD) - Choose one configuration method below

## Option 1: Weaviate Cloud Deployment
WCD_URL=https://your-cluster.weaviate.cloud
WCD_API_KEY=your-weaviate-api-key

## Option 2: Local Weaviate Instance
WEAVIATE_IS_LOCAL=True
LOCAL_WEAVIATE_PORT=8080
LOCAL_WEAVIATE_GRPC_PORT=50051

## Option 3: Custom Weaviate Instance
WEAVIATE_IS_CUSTOM=True
CUSTOM_HTTP_HOST=your.weaviate.host
CUSTOM_HTTP_PORT=443
CUSTOM_HTTP_SECURE=True
CUSTOM_GRPC_HOST=your.weaviate.host
CUSTOM_GRPC_PORT=443
CUSTOM_GRPC_SECURE=True

# ============================================================
# LLM PROVIDER API KEYS
# ============================================================

## OpenAI
OPENAI_API_KEY=sk-proj-...

## Anthropic
ANTHROPIC_API_KEY=sk-ant-...

## Google / Vertex AI
GEMINI_API_KEY=...
VERTEX_API_KEY=...
STUDIO_API_KEY=...

## OpenRouter (Multi-model gateway)
OPENROUTER_API_KEY=sk-or-...

## Other LLM Providers
COHERE_API_KEY=...
MISTRAL_API_KEY=...
HUGGINGFACE_API_KEY=hf_...
ANYSCALE_API_KEY=...
JINAAI_API_KEY=jina_...
NVIDIA_API_KEY=...
XAI_API_KEY=...
VOYAGE_API_KEY=...
VOYAGEAI_API_KEY=...
FRIENDLI_TOKEN=...
DATABRICKS_TOKEN=...

## Cloud Provider Credentials
AWS_ACCESS_KEY=AKIA...
AWS_SECRET_KEY=...
AZURE_API_KEY=...

# ============================================================
# MODEL CONFIGURATION
# ============================================================

BASE_MODEL=gemini-2.0-flash-001
COMPLEX_MODEL=gemini-2.0-flash-001
BASE_PROVIDER=openrouter/google
COMPLEX_PROVIDER=openrouter/google
MODEL_API_BASE=https://api.openrouter.ai/api/v1

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================

## Logging
LOGGING_LEVEL=INFO

## Timeout Settings (in seconds)
CLIENT_TIMEOUT=60
TREE_TIMEOUT=300
USER_TIMEOUT=600

## Environment
ENVIRONMENT=development
NODE_ENV=development

## Frontend URL (for CORS, API references)
NEXTJS_DEV_URL=http://localhost:3000

## Security
FERNET_KEY=your-fernet-key-for-encryption

# ============================================================
# PIPELINE & INGESTION CONFIGURATION
# ============================================================

PIPELINE_DATA_DIR=/home/user/projects/intellyweave/backend/pipeline/input_files
UNSTRUCTURED_API_URL=https://api.unstructuredapp.io
UNSTRUCTURED_API_KEY=...
# User id from backend/elysia/api/user_configs/frontend_config_4bf9a2fb5c4927c8f2c1f691a346c7e7.json file (exists only after first run)
INGESTION_USER_ID=4bf9a2fb5c4927c8f2c1f691a346c7e7 
INGEST_AUTO_PREPROCESS=true
INGEST_AUTO_GEOCODE=true
BATCH_WAIT_SECONDS=4

# ============================================================
# GEOSPATIAL SERVICES
# ============================================================

MAPBOX_ACCESS_TOKEN=pk.eyJ...

# ============================================================
# TESTING CONFIGURATION
# ============================================================

## Testing-specific Weaviate instance (optional, for test isolation)
TESTING_WCD_URL=https://your-test-cluster.weaviate.cloud
TESTING_WCD_API_KEY=your-test-weaviate-api-key

## Hugging Face Token (for downloading test models)
HF_TOKEN=hf_...
