# ============================================================
# PIPELINE WATCHDOG CONFIGURATION
# ============================================================
# This file configures the document ingestion pipeline (docker-compose service: pipeline-watchdog)
# Copy to .env and configure before running: docker compose up -d pipeline-watchdog

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOGGING_LEVEL=INFO

# Elysia backend API URL (the pipeline sends documents here)
ELYSIA_API_URL=http://localhost:8000

# Directory to watch for new documents (inside container: /app/data)
PIPELINE_DATA_DIR=/app/data

# User ID for document uploads (get from Elysia user registration)
PIPELINE_USER_ID=your-user-id-here

# Automatic processing options
PIPELINE_AUTO_PREPROCESS=true
PIPELINE_AUTO_GEOCODE=false

# Batch processing wait time (seconds to wait for more files before processing)
BATCH_WAIT_SECONDS=4

# ============================================================
# OPTIONAL: Unstructured API (for advanced document parsing)
# ============================================================
# UNSTRUCTURED_API_KEY=your-unstructured-api-key
# UNSTRUCTURED_API_URL=https://api.unstructuredapp.io/general/v0/general
